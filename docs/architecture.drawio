          <mxGeometry x="1200" y="120" width="520" height="760" as="geometry"/>
        </mxCell>

        <mxCell id="browser" value="Browser User&#xa;&#xa;Opens chat UI&#xa;Normal team workflow" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#111827;fontSize=18;fontStyle=1;align=center;verticalAlign=middle;spacing=6;" vertex="1" parent="1">
          <mxGeometry x="130" y="220" width="200" height="110" as="geometry"/>
        </mxCell>
        <mxCell id="sshpanel" value="SSH Panel&#xa;&#xa;Adds remote host&#xa;Only when SSH override is needed" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#111827;fontSize=18;fontStyle=1;align=center;verticalAlign=middle;spacing=6;" vertex="1" parent="1">
          <mxGeometry x="130" y="410" width="200" height="110" as="geometry"/>
        </mxCell>
        <mxCell id="cursor" value="Cursor / MCP&#xa;&#xa;Starts MCP server&#xa;Alternative to web UI" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#111827;fontSize=18;fontStyle=1;align=center;verticalAlign=middle;spacing=6;" vertex="1" parent="1">
          <mxGeometry x="130" y="600" width="200" height="110" as="geometry"/>
        </mxCell>

        <mxCell id="frontend" value="Next.js Frontend&#xa;&#xa;ui/frontend&#xa;&#xa;Collects messages, keeps session_id, manages SSH state, renders results." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#111827;fontSize=18;fontStyle=1;align=center;verticalAlign=middle;spacing=6;" vertex="1" parent="1">
          <mxGeometry x="520" y="200" width="250" height="140" as="geometry"/>
        </mxCell>
        <mxCell id="backend" value="FastAPI Backend&#xa;&#xa;main.py + routers + SQLite&#xa;&#xa;Receives REST calls, saves history, routes intent, dispatches tool calls." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#111827;fontSize=18;fontStyle=1;align=center;verticalAlign=middle;spacing=6;" vertex="1" parent="1">
          <mxGeometry x="840" y="200" width="270" height="140" as="geometry"/>
        </mxCell>
        <mxCell id="core" value="Shared MCP Core&#xa;&#xa;mcp&#xa;&#xa;wrappers.py&#xa;ai_tools/*.py&#xa;llm_service.py&#xa;&#xa;Used by both the web backend and MCP server." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#111827;strokeWidth=2;fontSize=18;fontStyle=1;align=center;verticalAlign=middle;spacing=6;" vertex="1" parent="1">
          <mxGeometry x="650" y="470" width="330" height="210" as="geometry"/>
        </mxCell>
        <mxCell id="mcpserver" value="MCP Server&#xa;&#xa;mcp_server/server.py + tools.py&#xa;&#xa;Registers tools and exposes the same shared core over stdio." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#111827;fontSize=18;fontStyle=1;align=center;verticalAlign=middle;spacing=6;" vertex="1" parent="1">
          <mxGeometry x="650" y="740" width="330" height="130" as="geometry"/>
        </mxCell>

        <mxCell id="k8s" value="Kubernetes Cluster&#xa;&#xa;Local kubeconfig path&#xa;Used by kubectl_runner.py" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#111827;fontSize=18;fontStyle=1;align=center;verticalAlign=middle;spacing=6;" vertex="1" parent="1">
          <mxGeometry x="1320" y="190" width="260" height="110" as="geometry"/>
        </mxCell>
        <mxCell id="remote" value="Remote Cluster Node&#xa;&#xa;SSH transport path&#xa;Used only for SSH-backed requests" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#111827;fontSize=18;fontStyle=1;align=center;verticalAlign=middle;spacing=6;" vertex="1" parent="1">
