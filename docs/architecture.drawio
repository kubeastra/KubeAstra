          <mxGeometry x="70" y="120" width="320" height="760" as="geometry"/>
        </mxCell>
        <mxCell id="zone-app" value="Application and Shared Core" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#F3F4F6;strokeColor=#D1D5DB;fontStyle=1;fontSize=16;verticalAlign=top;align=left;spacingTop=12;spacingLeft=14;" vertex="1" parent="1">
