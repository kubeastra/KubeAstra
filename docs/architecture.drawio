        </mxCell>

        <mxCell id="note-normal" value="When called: web UI path runs on every browser chat turn." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#94A3B8;fontSize=13;fontColor=#475569;align=center;verticalAlign=middle;" vertex="1" parent="1">
