# ── Kubernetes / kubectl ──────────────────────────────────────────────────────
# Comma-separated list of namespaces the server is allowed to query
ALLOWED_NAMESPACES=prod,staging,dev,default

# Path to kubeconfig (defaults to ~/.kube/config)
# KUBECONFIG_PATH=/home/user/.kube/config

# kubectl command timeout in seconds
KUBECTL_TIMEOUT_SECONDS=15

# Max log lines to return per request
MAX_LOG_TAIL_LINES=200

# Max bytes of output per tool response
MAX_OUTPUT_BYTES=20000

# Enable k8sgpt CLI integration (requires k8sgpt installed)
ENABLE_K8SGPT=false

# Enable write/recovery operations (delete_pod, rollout_restart, scale_deployment, apply_patch, exec_pod_command)
ENABLE_RECOVERY_OPERATIONS=false

# Max replicas allowed when scaling
MAX_SCALE_REPLICAS=100

# ── Deployment Repository ─────────────────────────────────────────────────────
DEPLOYMENT_REPO_URL=git@github.com:your-org/deployment-provisioning.git
# GITHUB_TOKEN=ghp_your_token_here  # for HTTPS private repos

# ── LLM provider ──────────────────────────────────────────────────────────────
# "gemini" (default, needs an API key) or "ollama" (fully local, no API key)
LLM_PROVIDER=gemini

# ── AI / Gemini ───────────────────────────────────────────────────────────────
# Get a free key at: https://aistudio.google.com/
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.5-flash

# ── Ollama (local LLM) ────────────────────────────────────────────────────────
# Install Ollama: https://ollama.com/  — then `ollama pull llama3.1`
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1

# ── Vector DB / RAG (optional — run: make docker-up to start Weaviate) ────────
WEAVIATE_URL=http://localhost:8080
WEAVIATE_COLLECTION=K8sAnsibleError

# ── Embeddings (local, no API key needed) ─────────────────────────────────────
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# ── HTTP MCP transport (optional) ─────────────────────────────────────────────
# Local Streamable HTTP endpoint for remote IDE / MCP testing
MCP_HTTP_HOST=127.0.0.1
MCP_HTTP_PORT=8001
MCP_HTTP_PATH=/mcp

# Optional bearer token for HTTP MCP clients
# MCP_HTTP_AUTH_TOKEN=dev-local-token
