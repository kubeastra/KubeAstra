# Personal overrides — ignore local-only .env files
# .env is intentionally tracked (shared Gemini key + app config)
# Only ignore local override files
.env.local
.env.*.local

# Runtime logs
*.log
audit.log

# SQLite session data
*.db
*.db-shm
*.db-wal

# Python bytecode
__pycache__/
*.pyc
*.pyo
*.pyd

# Virtual environment
venv/
.venv/

# Test / type-check caches
.pytest_cache/
.mypy_cache/
