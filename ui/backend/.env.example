# Path to mcp project (only needed when running outside Docker)
MCP_PATH=../../mcp

# ── LLM provider ──────────────────────────────────────────────────────────────
# "gemini" (default, needs an API key) or "ollama" (fully local, no API key)
LLM_PROVIDER=gemini

# ── AI / Gemini ───────────────────────────────────────────────────────────────
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.5-flash

# ── Ollama (local LLM) ────────────────────────────────────────────────────────
# Install Ollama: https://ollama.com/  — then `ollama pull llama3.1`
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1

# ── Kubernetes ────────────────────────────────────────────────────────────────
ALLOWED_NAMESPACES=*
KUBECTL_TIMEOUT_SECONDS=15
MAX_LOG_TAIL_LINES=200
ENABLE_RECOVERY_OPERATIONS=false

# ── Vector DB / RAG (optional) ────────────────────────────────────────────────
WEAVIATE_URL=http://localhost:8080
WEAVIATE_COLLECTION=K8sAnsibleError
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
